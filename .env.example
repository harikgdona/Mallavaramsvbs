# Copy to `.env.local` and fill in (`.env.local` is gitignored).
# Used by `npm run export-site-bundle` / `npm run deploy-from-browser`.

MALLAVARAM_ADMIN_USER=admin
MALLAVARAM_ADMIN_PASSWORD=
# If the password contains # or whitespace, use quotes, e.g. MALLAVARAM_ADMIN_PASSWORD="hari#678"
# Or put the password in a one-line file (path relative to repo root is ok):
# MALLAVARAM_ADMIN_PASSWORD_FILE=.mallavaram-admin-password

# Optional — host must match your browser (www vs non-www = different localStorage).
# You may omit the hash; the export script appends #configure automatically.
# MALLAVARAM_SITE_URL=https://mallavaramsvbs.org
#
# Local export: Next.js must be running (npm run dev), OR use:
#   .\Mallavaram-Workflows.ps1 -PlaywrightExportThenPushToGitHub -AutoStartDevServerIfLocalhost
# MALLAVARAM_SITE_URL=http://localhost:3000

# Optional — set to 1 to show the browser even when the password above is set (debug)
# MALLAVARAM_EXPORT_HEADED=1
