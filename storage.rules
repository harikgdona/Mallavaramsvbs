rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Public read for all site images
    match /site-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email.lower() in [
          'harikgdona@gmail.com',
          'koteswaragali@gmail.com'
        ];
    }
  }
}
