rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Site config: anyone can read, only authorized admins can write
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in [
          'harikgdona@gmail.com',
          'koteswaragali@gmail.com'
        ]
        // Rate limit: max 1 write per second per user
        && (!exists(/databases/$(database)/documents/config/$(document))
            || resource.data.updatedAt == null
            || request.time > timestamp.value(resource.data.updatedAt) + duration.value(1, 's'));
    }

    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
